# Handelsregister Scraper - Environment Variables
# Copy this file to .env and fill in your values.

# ===========================================
# DATABASE
# ===========================================
DB_PATH=handelsregister.db
# DATABASE_PATH=/data/handelsregister.db  # Use absolute path for Docker

# ===========================================
# WEB UI
# ===========================================
PORT=8000

# ===========================================
# API (optional — for handelsregister.ai enrichment)
# ===========================================
# HANDELSREGISTER_API_KEY=your_api_key_here

# ===========================================
# SCHEDULER
# ===========================================
DISCOVERY_INTERVAL_HOURS=2
# MAX_REQUESTS_PER_JOB=20

# ===========================================
# NOTIFICATIONS (optional)
# ===========================================
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# ALERT_EMAIL=alerts@yourcompany.com

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO
